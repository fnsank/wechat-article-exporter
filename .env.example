# 调试微信代理请求 (仅开发环境(development)支持)
NUXT_DEBUG_MP_REQUEST=false

# AG-Grid 企业版授权
NUXT_AGGRID_LICENSE=

# KV绑定(本地/docker)
NITRO_KV_DRIVER=fs
NITRO_KV_BASE=.data/kv

# KV绑定(cloudflare Workers/Pages 部署时使用)
# 使用方法：
#   1) 在 wrangler.jsonc 里以 binding: "KV" 绑定一个 KV Namespace
#   2) 本地 dev 时可选：CLOUDFLARE_KV_ID=<你的 KV namespace id>
#   3) 生产环境部署由 nuxt.config.ts 中的 nitro.cloudflare.wrangler 自动生成 wrangler.json
#NITRO_KV_DRIVER=cloudflare-kv-binding
#CLOUDFLARE_KV_ID=

# KV绑定(Upstash Redis, 适用于 Vercel 等无持久文件系统的环境)
# 免费额度: 500K 命令/月, 256MB 存储
#
# 方式 A: Vercel Marketplace 集成（推荐 Vercel 部署使用）
#   在 Vercel 项目 Storage 里添加 Upstash，会自动注入 KV_REST_API_URL / KV_REST_API_TOKEN
#   等变量。你只需要额外手动设置 NITRO_KV_DRIVER=upstash 即可。
#
# 方式 B: 直接在 Upstash 控制台创建后自填
#   1) 在 https://console.upstash.com 创建 Redis 数据库
#   2) 从 "REST API" 选项卡复制 URL 与 Token
#   3) 设置以下三个环境变量:
#NITRO_KV_DRIVER=upstash
#UPSTASH_REDIS_REST_URL=
#UPSTASH_REDIS_REST_TOKEN=

DEBUG_KEY=

# Single-user admin page key.
ADMIN_KEY=

# Stable key used by AI/automation clients.
API_KEY=
